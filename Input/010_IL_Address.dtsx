                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=11.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 	
		 AD_TK AS AddressIdentifier
		,AD_TX_1 AS AddressLine1Text
		,AD_TX_2 AS AddressLine2Text
		,AD_TX_3 AS AddressLine3Text
		,AD_CTY_NM AS AddressCityName
		,AD_ZIP_CD_NU AS AddressPostalCode
		,AD_ST_CD AS AddressStateCode
		,AD_CNY_CD AS AddressCountyCode
		,AD_CRY_CD AS AddressCountryCode
		,'I' AS Operation
		,AD_UPD_TS AS SourceUpdateTS
FROM AD 
WHERE CAST(YEAR(CAST(LEFT(AD_UPD_TS, 10) AS date)) AS varchar) = ?
ORDER BY SourceUpdateTS,AddressIdentifier;</property>
