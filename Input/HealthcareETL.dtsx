              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformClaims\RC_Claims.Outputs[Row Count Output 1]" name="Row Count Output 1" synchronousInputId="Package\DFT_TransformClaims\RC_Claims.Inputs[Row Count Input 1]"/>
              </outputs>
            </component>

            <!-- Destination: Transformed Claims -->
            <component
              refId="Package\DFT_TransformClaims\DST_TransformedClaims"
              componentClassID="Microsoft.OLEDBDestination"
              contactInfo="OLE DB Destination"
              description="Load transformed claims data"
              name="DST_TransformedClaims"
