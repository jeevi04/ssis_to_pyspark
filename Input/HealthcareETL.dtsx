    <DTS:Executable
      DTS:refId="Package\DFT_TransformMembers"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:Description="Read and transform member data with gender and zip standardization"
      DTS:DTSID="{DFT00001-0001-0001-0001-000000000001}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="DFT_TransformMembers"
      DTS:TaskContact="Microsoft Corporation; Microsoft SQL Server; Microsoft Corporation">

      <DTS:ObjectData>
        <pipeline version="1" BLOBTempStoragePath="" bufferTempStoragePath="">
          <components>

            <!-- Source: Member Table -->
            <component
              refId="Package\DFT_TransformMembers\SRC_Member"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source"
              description="OLE DB Source - Member Table"
              name="SRC_Member"
              usesDispositions="true"
              version="7">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="OpenRowset" dataType="System.String">dbo.member</property>
                <property name="AccessMode" dataType="System.Int32">0</property>
                <property name="SqlCommand" dataType="System.String">SELECT
    member_id,
    mrn,
    first_name,
    last_name,
    date_of_birth,
    gender,
    address_line1,
    city,
    state,
    zip_code,
    phone,
    email,
    race,
    ethnicity,
    death_date,
    created_timestamp,
    updated_timestamp
FROM dbo.member</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_TransformMembers\SRC_Member.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[SourceDB]"
                  connectionManagerRefId="Package.ConnectionManagers[SourceDB]"
                  name="OleDbConnection"/>
              </connections>
              <outputs>
                <output refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output]"
                  name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[member_id]" dataType="wstr" length="50" name="member_id"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[mrn]" dataType="wstr" length="50" name="mrn"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[first_name]" dataType="wstr" length="100" name="first_name"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[last_name]" dataType="wstr" length="100" name="last_name"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[date_of_birth]" dataType="dbDate" name="date_of_birth"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[gender]" dataType="wstr" length="10" name="gender"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[address_line1]" dataType="wstr" length="200" name="address_line1"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[city]" dataType="wstr" length="100" name="city"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[state]" dataType="wstr" length="10" name="state"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[zip_code]" dataType="wstr" length="10" name="zip_code"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[phone]" dataType="wstr" length="20" name="phone"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[email]" dataType="wstr" length="100" name="email"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[race]" dataType="wstr" length="50" name="race"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[ethnicity]" dataType="wstr" length="50" name="ethnicity"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[death_date]" dataType="dbDate" name="death_date"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[created_timestamp]" dataType="dbTimeStamp" name="created_timestamp"/>
                    <outputColumn refId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[updated_timestamp]" dataType="dbTimeStamp" name="updated_timestamp"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Derived Column: Gender Standardization -->
            <component
              refId="Package\DFT_TransformMembers\DER_GenderStandardization"
              componentClassID="Microsoft.DerivedColumn"
              contactInfo="Derived Column Transformation"
              description="Standardize gender codes to M/F/U/Other"
              name="DER_GenderStandardization"
              usesDispositions="true">
              <inputs>
                <input refId="Package\DFT_TransformMembers\DER_GenderStandardization.Inputs[Derived Column Input]"
                  name="Derived Column Input">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_TransformMembers\DER_GenderStandardization.Inputs[Derived Column Input].Columns[gender]"
                      cachedDataType="wstr"
                      cachedLength="10"
                      cachedName="gender"
                      lineageId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[gender]"/>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformMembers\DER_GenderStandardization.Outputs[Derived Column Output]"
                  name="Derived Column Output">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT_TransformMembers\DER_GenderStandardization.Outputs[Derived Column Output].Columns[gender_standardized]"
                      dataType="wstr"
                      length="10"
                      lineageId="Package\DFT_TransformMembers\DER_GenderStandardization.Outputs[Derived Column Output].Columns[gender_standardized]"
                      name="gender_standardized">
                      <properties>
                        <property name="Expression" dataType="System.String">UPPER(TRIM(gender)) == "M" || UPPER(TRIM(gender)) == "MALE" ? "M" :
(UPPER(TRIM(gender)) == "F" || UPPER(TRIM(gender)) == "FEMALE" ? "F" :
(UPPER(TRIM(gender)) == "U" || UPPER(TRIM(gender)) == "UNKNOWN" || ISNULL(gender) ? "U" : "Other"))</property>
                        <property name="FriendlyExpression" dataType="System.String">Standardize gender to M/F/U/Other</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Derived Column: Zip Code Standardization -->
            <component
              refId="Package\DFT_TransformMembers\DER_ZipCodeStandardization"
              componentClassID="Microsoft.DerivedColumn"
              contactInfo="Derived Column Transformation"
              description="Standardize zip codes to 5 digit or ZIP+4 format"
              name="DER_ZipCodeStandardization"
              usesDispositions="true">
              <inputs>
                <input refId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Inputs[Derived Column Input]"
                  name="Derived Column Input">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Inputs[Derived Column Input].Columns[zip_code]"
                      cachedDataType="wstr"
                      cachedLength="10"
                      cachedName="zip_code"
                      lineageId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[zip_code]"/>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Outputs[Derived Column Output]"
                  name="Derived Column Output">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Outputs[Derived Column Output].Columns[zip_code_standardized]"
                      dataType="wstr"
                      length="10"
                      lineageId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Outputs[Derived Column Output].Columns[zip_code_standardized]"
                      name="zip_code_standardized">
                      <properties>
                        <property name="Expression" dataType="System.String">LEN(REPLACE(REPLACE(TRIM(zip_code),"-","")," ","")) == 9 ?
  SUBSTRING(REPLACE(REPLACE(TRIM(zip_code),"-","")," ",""),1,5) + "-" + SUBSTRING(REPLACE(REPLACE(TRIM(zip_code),"-","")," ",""),6,4) :
  (LEN(REPLACE(REPLACE(TRIM(zip_code),"-","")," ","")) >= 5 ?
    SUBSTRING(REPLACE(REPLACE(TRIM(zip_code),"-","")," ",""),1,5) :
    RIGHT("00000" + REPLACE(REPLACE(TRIM(zip_code),"-","")," ",""),5))</property>
                        <property name="FriendlyExpression" dataType="System.String">Standardize zip to 5-digit or ZIP+4 format</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Row Count: Members -->
            <component
              refId="Package\DFT_TransformMembers\RC_Members"
              componentClassID="Microsoft.RowCount"
              description="Count member rows processed"
              name="RC_Members">
              <properties>
                <property name="VariableName" dataType="System.String">User::RowCount_Members</property>
              </properties>
              <inputs>
                <input refId="Package\DFT_TransformMembers\RC_Members.Inputs[Row Count Input 1]" name="Row Count Input 1"/>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformMembers\RC_Members.Outputs[Row Count Output 1]" name="Row Count Output 1" synchronousInputId="Package\DFT_TransformMembers\RC_Members.Inputs[Row Count Input 1]"/>
              </outputs>
            </component>

            <!-- Destination: Transformed Members -->
            <component
              refId="Package\DFT_TransformMembers\DST_TransformedMembers"
              componentClassID="Microsoft.OLEDBDestination"
              contactInfo="OLE DB Destination"
              description="Load transformed member data"
              name="DST_TransformedMembers"
              usesDispositions="true"
              version="4">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="OpenRowset" dataType="System.String">dbo.member_transformed</property>
                <property name="AccessMode" dataType="System.Int32">3</property>
                <property name="FastLoadKeepIdentity" dataType="System.Boolean">false</property>
                <property name="FastLoadKeepNulls" dataType="System.Boolean">false</property>
                <property name="FastLoadMaxInsertCommitSize" dataType="System.Int32">2147483647</property>
                <property name="FastLoadOptions" dataType="System.String">TABLOCK,CHECK_CONSTRAINTS</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_TransformMembers\DST_TransformedMembers.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[TargetDB]"
                  connectionManagerRefId="Package.ConnectionManagers[TargetDB]"
                  name="OleDbConnection"/>
              </connections>
              <inputs>
                <input refId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input]" name="OLE DB Destination Input">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input].Columns[member_id]" externalMetadataColumnId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input].ExternalColumns[member_id]" lineageId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output].Columns[member_id]"/>
                    <inputColumn refId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input].Columns[gender_standardized]" externalMetadataColumnId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input].ExternalColumns[gender_cd]" lineageId="Package\DFT_TransformMembers\DER_GenderStandardization.Outputs[Derived Column Output].Columns[gender_standardized]"/>
                    <inputColumn refId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input].Columns[zip_code_standardized]" externalMetadataColumnId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input].ExternalColumns[zip_code]" lineageId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Outputs[Derived Column Output].Columns[zip_code_standardized]"/>
                  </inputColumns>
                </input>
              </inputs>
            </component>

          </components>

          <!-- Data Flow Paths for Member Transform -->
          <paths>
            <path refId="Package\DFT_TransformMembers.Paths[Source to Gender]"
              endId="Package\DFT_TransformMembers\DER_GenderStandardization.Inputs[Derived Column Input]"
              name="Source to Gender"
              startId="Package\DFT_TransformMembers\SRC_Member.Outputs[OLE DB Source Output]"/>
            <path refId="Package\DFT_TransformMembers.Paths[Gender to Zip]"
              endId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Inputs[Derived Column Input]"
              name="Gender to Zip"
              startId="Package\DFT_TransformMembers\DER_GenderStandardization.Outputs[Derived Column Output]"/>
            <path refId="Package\DFT_TransformMembers.Paths[Zip to RowCount]"
              endId="Package\DFT_TransformMembers\RC_Members.Inputs[Row Count Input 1]"
              name="Zip to RowCount"
              startId="Package\DFT_TransformMembers\DER_ZipCodeStandardization.Outputs[Derived Column Output]"/>
            <path refId="Package\DFT_TransformMembers.Paths[RowCount to Destination]"
              endId="Package\DFT_TransformMembers\DST_TransformedMembers.Inputs[OLE DB Destination Input]"
              name="RowCount to Destination"
              startId="Package\DFT_TransformMembers\RC_Members.Outputs[Row Count Output 1]"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ========================================== -->
    <!-- TASK 2: Data Flow - Transform Claims with NPI Lookup -->
    <!-- ========================================== -->
    <DTS:Executable
      DTS:refId="Package\DFT_TransformClaims"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:Description="Read and transform claims data with provider NPI lookup"
      DTS:DTSID="{DFT00002-0002-0002-0002-000000000002}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="DFT_TransformClaims"
      DTS:TaskContact="Microsoft Corporation; Microsoft SQL Server; Microsoft Corporation">

      <DTS:ObjectData>
        <pipeline version="1">
          <components>

            <!-- Source: Claims 837 Table -->
            <component
              refId="Package\DFT_TransformClaims\SRC_Claims837"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source"
              description="OLE DB Source - Claims 837 Table"
              name="SRC_Claims837"
              usesDispositions="true"
              version="7">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="AccessMode" dataType="System.Int32">2</property>
                <property name="SqlCommand" dataType="System.String">SELECT
    claim_id,
    member_id,
    patient_control_number,
    provider_npi,
    billing_provider,
    claim_status,
    total_charge_amount,
    paid_amount,
    service_date_start,
    service_date_end,
    diagnosis_code1,
    diagnosis_code2,
    procedure_code1,
    procedure_code2,
    claim_frequency,
    prior_auth_number,
    created_timestamp,
    updated_timestamp
FROM dbo.claims_837</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_TransformClaims\SRC_Claims837.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[SourceDB]"
                  connectionManagerRefId="Package.ConnectionManagers[SourceDB]"
                  name="OleDbConnection"/>
              </connections>
              <outputs>
                <output refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output]"
                  name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[claim_id]" dataType="wstr" length="50" name="claim_id"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[member_id]" dataType="wstr" length="50" name="member_id"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[patient_control_number]" dataType="wstr" length="50" name="patient_control_number"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[provider_npi]" dataType="wstr" length="20" name="provider_npi"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[billing_provider]" dataType="wstr" length="100" name="billing_provider"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[claim_status]" dataType="wstr" length="10" name="claim_status"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[total_charge_amount]" dataType="numeric" precision="10" scale="2" name="total_charge_amount"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[paid_amount]" dataType="numeric" precision="10" scale="2" name="paid_amount"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[service_date_start]" dataType="dbDate" name="service_date_start"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[service_date_end]" dataType="dbDate" name="service_date_end"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[diagnosis_code1]" dataType="wstr" length="20" name="diagnosis_code1"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[diagnosis_code2]" dataType="wstr" length="20" name="diagnosis_code2"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[procedure_code1]" dataType="wstr" length="20" name="procedure_code1"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[procedure_code2]" dataType="wstr" length="20" name="procedure_code2"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[claim_frequency]" dataType="wstr" length="5" name="claim_frequency"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[prior_auth_number]" dataType="wstr" length="50" name="prior_auth_number"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[created_timestamp]" dataType="dbTimeStamp" name="created_timestamp"/>
                    <outputColumn refId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[updated_timestamp]" dataType="dbTimeStamp" name="updated_timestamp"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Lookup: Provider NPI to Provider Name -->
            <component
              refId="Package\DFT_TransformClaims\LKP_ProviderNPI"
              componentClassID="Microsoft.Lookup"
              contactInfo="Lookup Transformation"
              description="Lookup provider name from NPI registry"
              name="LKP_ProviderNPI"
              usesDispositions="true"
              version="6">
              <properties>
                <property name="CacheType" dataType="System.Int32">0</property>
                <property name="NoMatchBehavior" dataType="System.Int32">1</property>
                <property name="NoMatchCachePercentage" dataType="System.Int32">0</property>
                <property name="MaxMemoryUsage" dataType="System.Int32">25</property>
                <property name="MaxMemoryUsage64" dataType="System.Int64">25</property>
                <property name="ReferenceMetadataXml" dataType="System.String">&lt;referenceColumns&gt;&lt;referenceColumn name="npi" dataType="DT_WSTR" length="10" /&gt;&lt;referenceColumn name="provider_name" dataType="DT_WSTR" length="200" /&gt;&lt;referenceColumn name="provider_type" dataType="DT_WSTR" length="50" /&gt;&lt;referenceColumn name="taxonomy_code" dataType="DT_WSTR" length="20" /&gt;&lt;/referenceColumns&gt;</property>
                <property name="SqlCommand" dataType="System.String">SELECT
    npi,
    provider_organization_name + COALESCE(' - ' + provider_first_name + ' ' + provider_last_name, '') AS provider_name,
    entity_type_code AS provider_type,
    healthcare_provider_taxonomy_code_1 AS taxonomy_code
FROM dbo.npi_registry
WHERE npi IS NOT NULL</property>
                <property name="SqlCommandParam" dataType="System.String"></property>
                <property name="ParameterMap" dataType="System.String"></property>
                <property name="DefaultCodePage" dataType="System.Int32">1252</property>
                <property name="TreatDuplicateKeysAsError" dataType="System.Boolean">false</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[NPILookupDB]"
                  connectionManagerRefId="Package.ConnectionManagers[NPILookupDB]"
                  name="OleDbConnection"/>
              </connections>
              <inputs>
                <input refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Inputs[Lookup Input]"
                  name="Lookup Input">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Inputs[Lookup Input].Columns[provider_npi]"
                      cachedDataType="wstr"
                      cachedLength="20"
                      cachedName="provider_npi"
                      lineageId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[provider_npi]">
                      <properties>
                        <property name="JoinToReferenceColumn" dataType="System.String">npi</property>
                        <property name="CopyFromReferenceColumn" dataType="System.String"></property>
                      </properties>
                    </inputColumn>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Outputs[Lookup Match Output]"
                  name="Lookup Match Output">
                  <outputColumns>
                    <outputColumn refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Outputs[Lookup Match Output].Columns[provider_name_standardized]"
                      dataType="wstr"
                      length="200"
                      lineageId="Package\DFT_TransformClaims\LKP_ProviderNPI.Outputs[Lookup Match Output].Columns[provider_name_standardized]"
                      name="provider_name_standardized">
                      <properties>
                        <property name="CopyFromReferenceColumn" dataType="System.String">provider_name</property>
                      </properties>
                    </outputColumn>
                    <outputColumn refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Outputs[Lookup Match Output].Columns[provider_type]"
                      dataType="wstr"
                      length="50"
                      lineageId="Package\DFT_TransformClaims\LKP_ProviderNPI.Outputs[Lookup Match Output].Columns[provider_type]"
                      name="provider_type">
                      <properties>
                        <property name="CopyFromReferenceColumn" dataType="System.String">provider_type</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
                <output refId="Package\DFT_TransformClaims\LKP_ProviderNPI.Outputs[Lookup No Match Output]"
                  name="Lookup No Match Output"/>
              </outputs>
            </component>

            <!-- Derived Column: Inpatient Flag for Claims -->
            <component
              refId="Package\DFT_TransformClaims\DER_ClaimType"
              componentClassID="Microsoft.DerivedColumn"
              contactInfo="Derived Column Transformation"
              description="Derive claim type flags (inpatient/outpatient)"
              name="DER_ClaimType"
              usesDispositions="true">
              <inputs>
                <input refId="Package\DFT_TransformClaims\DER_ClaimType.Inputs[Derived Column Input]"
                  name="Derived Column Input">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_TransformClaims\DER_ClaimType.Inputs[Derived Column Input].Columns[claim_frequency]"
                      cachedDataType="wstr"
                      cachedLength="5"
                      cachedName="claim_frequency"
                      lineageId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[claim_frequency]"/>
                    <inputColumn refId="Package\DFT_TransformClaims\DER_ClaimType.Inputs[Derived Column Input].Columns[procedure_code1]"
                      cachedDataType="wstr"
                      cachedLength="20"
                      cachedName="procedure_code1"
                      lineageId="Package\DFT_TransformClaims\SRC_Claims837.Outputs[OLE DB Source Output].Columns[procedure_code1]"/>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformClaims\DER_ClaimType.Outputs[Derived Column Output]"
                  name="Derived Column Output">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT_TransformClaims\DER_ClaimType.Outputs[Derived Column Output].Columns[is_inpatient]"
                      dataType="bool"
                      lineageId="Package\DFT_TransformClaims\DER_ClaimType.Outputs[Derived Column Output].Columns[is_inpatient]"
                      name="is_inpatient">
                      <properties>
                        <property name="Expression" dataType="System.String">claim_frequency == "1" || claim_frequency == "7" || (SUBSTRING(procedure_code1,1,2) >= "99" &amp;&amp; SUBSTRING(procedure_code1,1,3) &lt;= "99223")</property>
                        <property name="FriendlyExpression" dataType="System.String">Identify inpatient claims based on frequency code and procedure codes</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_TransformClaims\DER_ClaimType.Outputs[Derived Column Output].Columns[claim_year]"
                      dataType="i4"
                      lineageId="Package\DFT_TransformClaims\DER_ClaimType.Outputs[Derived Column Output].Columns[claim_year]"
                      name="claim_year">
                      <properties>
                        <property name="Expression" dataType="System.String">YEAR(service_date_start)</property>
                        <property name="FriendlyExpression" dataType="System.String">Extract year from service date for patient journey</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Union All: Combine matched and unmatched NPI lookups -->
            <component
              refId="Package\DFT_TransformClaims\UNION_ProviderResults"
              componentClassID="Microsoft.UnionAll"
              description="Combine matched and unmatched provider lookups"
              name="UNION_ProviderResults">
              <inputs>
                <input refId="Package\DFT_TransformClaims\UNION_ProviderResults.Inputs[Union All Input 1]" name="Union All Input 1"/>
                <input refId="Package\DFT_TransformClaims\UNION_ProviderResults.Inputs[Union All Input 2]" name="Union All Input 2"/>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformClaims\UNION_ProviderResults.Outputs[Union All Output 1]" name="Union All Output 1"/>
              </outputs>
            </component>

            <!-- Row Count: Claims -->
            <component
              refId="Package\DFT_TransformClaims\RC_Claims"
              componentClassID="Microsoft.RowCount"
              description="Count claims rows processed"
              name="RC_Claims">
