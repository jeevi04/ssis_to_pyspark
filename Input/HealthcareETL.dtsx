              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source"
              description="Union claims and pharmacy for patient journey"
              name="SRC_PatientJourney"
              usesDispositions="true"
              version="7">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="AccessMode" dataType="System.Int32">2</property>
                <property name="SqlCommand" dataType="System.String">-- Combine claims and pharmacy encounters for patient journey
SELECT
    member_id,
    claim_year AS encounter_year,
    'MEDICAL' AS encounter_type,
    service_date_start AS encounter_date,
    1 AS encounter_count
FROM dbo.claims_transformed
UNION ALL
SELECT
    member_id,
    rx_year AS encounter_year,
    'PHARMACY' AS encounter_type,
    fill_date AS encounter_date,
    1 AS encounter_count
FROM dbo.pharmacy_transformed</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_PatientJourney\SRC_PatientJourney.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[TargetDB]"
                  connectionManagerRefId="Package.ConnectionManagers[TargetDB]"
                  name="OleDbConnection"/>
              </connections>
              <outputs>
                <output refId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output]"
                  name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn refId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[member_id]" dataType="wstr" length="50" name="member_id"/>
                    <outputColumn refId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_year]" dataType="i4" name="encounter_year"/>
                    <outputColumn refId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_type]" dataType="wstr" length="20" name="encounter_type"/>
                    <outputColumn refId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_date]" dataType="dbDate" name="encounter_date"/>
                    <outputColumn refId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_count]" dataType="i4" name="encounter_count"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Aggregate: Patient Journey by Member and Year -->
            <component
              refId="Package\DFT_PatientJourney\AGG_PatientJourney"
              componentClassID="Microsoft.Aggregate"
              contactInfo="Aggregate Transformation"
              description="Aggregate patient journey by member and year"
              name="AGG_PatientJourney"
              version="3">
              <properties>
                <property name="KeyDuplicates" dataType="System.Int32">0</property>
                <property name="Keys" dataType="System.Int32">0</property>
                <property name="CountDistinctKeys" dataType="System.Int32">0</property>
                <property name="AutoExtendFactor" dataType="System.Int32">25</property>
              </properties>
              <inputs>
                <input refId="Package\DFT_PatientJourney\AGG_PatientJourney.Inputs[Aggregate Input 1]"
                  name="Aggregate Input 1">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_PatientJourney\AGG_PatientJourney.Inputs[Aggregate Input 1].Columns[member_id]"
                      cachedDataType="wstr"
                      cachedLength="50"
                      cachedName="member_id"
                      lineageId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[member_id]"/>
                    <inputColumn refId="Package\DFT_PatientJourney\AGG_PatientJourney.Inputs[Aggregate Input 1].Columns[encounter_year]"
                      cachedDataType="i4"
                      cachedName="encounter_year"
                      lineageId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_year]"/>
                    <inputColumn refId="Package\DFT_PatientJourney\AGG_PatientJourney.Inputs[Aggregate Input 1].Columns[encounter_count]"
                      cachedDataType="i4"
                      cachedName="encounter_count"
                      lineageId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_count]"/>
                    <inputColumn refId="Package\DFT_PatientJourney\AGG_PatientJourney.Inputs[Aggregate Input 1].Columns[encounter_date]"
                      cachedDataType="dbDate"
                      cachedName="encounter_date"
                      lineageId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output].Columns[encounter_date]"/>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1]"
                  name="Aggregate Output 1">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[member_id]"
                      dataType="wstr"
                      length="50"
                      lineageId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[member_id]"
                      name="member_id">
                      <properties>
                        <property name="AggregationType" dataType="System.Int32">0</property>
                        <property name="AggregationColumnId" dataType="System.Int32">0</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[encounter_year]"
                      dataType="i4"
                      lineageId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[encounter_year]"
                      name="encounter_year">
                      <properties>
                        <property name="AggregationType" dataType="System.Int32">0</property>
                        <property name="AggregationColumnId" dataType="System.Int32">1</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[total_encounters]"
                      dataType="i8"
                      lineageId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[total_encounters]"
                      name="total_encounters">
                      <properties>
                        <property name="AggregationType" dataType="System.Int32">4</property>
                        <property name="AggregationColumnId" dataType="System.Int32">2</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[first_encounter_date]"
                      dataType="dbDate"
                      lineageId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[first_encounter_date]"
                      name="first_encounter_date">
                      <properties>
                        <property name="AggregationType" dataType="System.Int32">6</property>
                        <property name="AggregationColumnId" dataType="System.Int32">3</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[last_encounter_date]"
                      dataType="dbDate"
                      lineageId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[last_encounter_date]"
                      name="last_encounter_date">
                      <properties>
                        <property name="AggregationType" dataType="System.Int32">7</property>
                        <property name="AggregationColumnId" dataType="System.Int32">3</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[distinct_years]"
                      dataType="i4"
                      lineageId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1].Columns[distinct_years]"
                      name="distinct_years">
                      <properties>
                        <property name="AggregationType" dataType="System.Int32">3</property>
                        <property name="AggregationColumnId" dataType="System.Int32">1</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Destination: Patient Journey -->
            <component
              refId="Package\DFT_PatientJourney\DST_PatientJourney"
              componentClassID="Microsoft.OLEDBDestination"
              contactInfo="OLE DB Destination"
              description="Load patient journey data"
              name="DST_PatientJourney"
              usesDispositions="true"
              version="4">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="OpenRowset" dataType="System.String">dbo.patient_journey</property>
                <property name="AccessMode" dataType="System.Int32">3</property>
                <property name="FastLoadKeepIdentity" dataType="System.Boolean">false</property>
                <property name="FastLoadKeepNulls" dataType="System.Boolean">false</property>
                <property name="FastLoadMaxInsertCommitSize" dataType="System.Int32">2147483647</property>
                <property name="FastLoadOptions" dataType="System.String">TABLOCK,CHECK_CONSTRAINTS</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_PatientJourney\DST_PatientJourney.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[TargetDB]"
                  connectionManagerRefId="Package.ConnectionManagers[TargetDB]"
                  name="OleDbConnection"/>
              </connections>
              <inputs>
                <input refId="Package\DFT_PatientJourney\DST_PatientJourney.Inputs[OLE DB Destination Input]" name="OLE DB Destination Input"/>
              </inputs>
            </component>

          </components>

          <!-- Data Flow Paths for Patient Journey -->
          <paths>
            <path refId="Package\DFT_PatientJourney.Paths[Source to Aggregate]"
              endId="Package\DFT_PatientJourney\AGG_PatientJourney.Inputs[Aggregate Input 1]"
              name="Source to Aggregate"
              startId="Package\DFT_PatientJourney\SRC_PatientJourney.Outputs[OLE DB Source Output]"/>
            <path refId="Package\DFT_PatientJourney.Paths[Aggregate to Destination]"
              endId="Package\DFT_PatientJourney\DST_PatientJourney.Inputs[OLE DB Destination Input]"
              name="Aggregate to Destination"
              startId="Package\DFT_PatientJourney\AGG_PatientJourney.Outputs[Aggregate Output 1]"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <!-- Precedence Constraints (Control Flow Order) -->
  <DTS:PrecedenceConstraints>
    <!-- Transform Members -> Transform Claims -->
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Members to Claims]"
      DTS:CreationName=""
      DTS:DTSID="{PC000001-0001-0001-0001-000000000001}"
      DTS:From="Package\DFT_TransformMembers"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Members to Claims"
      DTS:To="Package\DFT_TransformClaims"/>

    <!-- Transform Members -> Transform Pharmacy (parallel with Claims) -->
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Members to Pharmacy]"
      DTS:CreationName=""
      DTS:DTSID="{PC000002-0002-0002-0002-000000000002}"
      DTS:From="Package\DFT_TransformMembers"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Members to Pharmacy"
      DTS:To="Package\DFT_TransformPharmacy"/>

    <!-- Transform Claims -> Member Claims Aggregation -->
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Claims to ClaimsAgg]"
      DTS:CreationName=""
      DTS:DTSID="{PC000003-0003-0003-0003-000000000003}"
      DTS:From="Package\DFT_TransformClaims"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Claims to ClaimsAgg"
      DTS:To="Package\DFT_MemberClaimsAggregation"/>

    <!-- Transform Pharmacy -> Pharmacy Aggregation -->
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Pharmacy to PharmacyAgg]"
      DTS:CreationName=""
      DTS:DTSID="{PC000004-0004-0004-0004-000000000004}"
      DTS:From="Package\DFT_TransformPharmacy"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Pharmacy to PharmacyAgg"
      DTS:To="Package\DFT_PharmacyAggregation"/>

    <!-- Member Claims Aggregation -> Patient Journey -->
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[ClaimsAgg to Journey]"
      DTS:CreationName=""
      DTS:DTSID="{PC000005-0005-0005-0005-000000000005}"
      DTS:From="Package\DFT_MemberClaimsAggregation"
      DTS:LogicalAnd="True"
      DTS:ObjectName="ClaimsAgg to Journey"
      DTS:To="Package\DFT_PatientJourney"/>

    <!-- Pharmacy Aggregation -> Patient Journey -->
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[PharmacyAgg to Journey]"
      DTS:CreationName=""
      DTS:DTSID="{PC000006-0006-0006-0006-000000000006}"
      DTS:From="Package\DFT_PharmacyAggregation"
      DTS:LogicalAnd="True"
      DTS:ObjectName="PharmacyAgg to Journey"
      DTS:To="Package\DFT_PatientJourney"/>
  </DTS:PrecedenceConstraints>

</DTS:Executable>
