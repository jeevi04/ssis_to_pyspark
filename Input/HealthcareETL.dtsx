    <!-- ========================================== -->
    <!-- TASK 3: Data Flow - Transform Pharmacy with NDC Standardization -->
    <!-- ========================================== -->
    <DTS:Executable
      DTS:refId="Package\DFT_TransformPharmacy"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:Description="Read and transform pharmacy data with NDC standardization"
      DTS:DTSID="{DFT00003-0003-0003-0003-000000000003}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="DFT_TransformPharmacy"
      DTS:TaskContact="Microsoft Corporation; Microsoft SQL Server; Microsoft Corporation">

      <DTS:ObjectData>
        <pipeline version="1">
          <components>

            <!-- Source: PBM Pharmacy Table -->
            <component
              refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source"
              description="OLE DB Source - PBM Pharmacy Table"
              name="SRC_PBMPharmacy"
              usesDispositions="true"
              version="7">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="AccessMode" dataType="System.Int32">2</property>
                <property name="SqlCommand" dataType="System.String">SELECT
    rx_claim_id,
    member_id,
    rx_number,
    ndc_code,
    drug_name,
    drug_strength,
    quantity,
    days_supply,
    fill_date,
    dispense_pharmacy_npi,
    dispense_pharmacy_name,
    ingredient_cost,
    total_cost,
    paid_amount,
    bin,
    pcin,
    created_timestamp,
    updated_timestamp
FROM source.pbm_pharmacy</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[SourceDB]"
                  connectionManagerRefId="Package.ConnectionManagers[SourceDB]"
                  name="OleDbConnection"/>
              </connections>
              <outputs>
                <output refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output]"
                  name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[rx_claim_id]" dataType="wstr" length="50" name="rx_claim_id"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[member_id]" dataType="wstr" length="50" name="member_id"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[rx_number]" dataType="wstr" length="50" name="rx_number"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[ndc_code]" dataType="wstr" length="20" name="ndc_code"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[drug_name]" dataType="wstr" length="200" name="drug_name"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[drug_strength]" dataType="wstr" length="50" name="drug_strength"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[quantity]" dataType="numeric" precision="10" scale="3" name="quantity"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[days_supply]" dataType="i4" name="days_supply"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[fill_date]" dataType="dbDate" name="fill_date"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[dispense_pharmacy_npi]" dataType="wstr" length="20" name="dispense_pharmacy_npi"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[dispense_pharmacy_name]" dataType="wstr" length="200" name="dispense_pharmacy_name"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[ingredient_cost]" dataType="numeric" precision="10" scale="2" name="ingredient_cost"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[total_cost]" dataType="numeric" precision="10" scale="2" name="total_cost"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[paid_amount]" dataType="numeric" precision="10" scale="2" name="paid_amount"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[bin]" dataType="wstr" length="20" name="bin"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[pcin]" dataType="wstr" length="50" name="pcin"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[created_timestamp]" dataType="dbTimeStamp" name="created_timestamp"/>
                    <outputColumn refId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[updated_timestamp]" dataType="dbTimeStamp" name="updated_timestamp"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Derived Column: NDC Code Standardization to 11 digits -->
            <component
              refId="Package\DFT_TransformPharmacy\DER_NDCStandardization"
              componentClassID="Microsoft.DerivedColumn"
              contactInfo="Derived Column Transformation"
              description="Standardize NDC codes to 11-digit format (5-4-2)"
              name="DER_NDCStandardization"
              usesDispositions="true">
              <inputs>
                <input refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Inputs[Derived Column Input]"
                  name="Derived Column Input">
                  <inputColumns>
                    <inputColumn refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Inputs[Derived Column Input].Columns[ndc_code]"
                      cachedDataType="wstr"
                      cachedLength="20"
                      cachedName="ndc_code"
                      lineageId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[ndc_code]"/>
                    <inputColumn refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Inputs[Derived Column Input].Columns[fill_date]"
                      cachedDataType="dbDate"
                      cachedName="fill_date"
                      lineageId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output].Columns[fill_date]"/>
                  </inputColumns>
                </input>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output]"
                  name="Derived Column Output">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output].Columns[ndc_code_standardized]"
                      dataType="wstr"
                      length="11"
                      lineageId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output].Columns[ndc_code_standardized]"
                      name="ndc_code_standardized">
                      <properties>
                        <property name="Expression" dataType="System.String">RIGHT("00000000000" + REPLACE(REPLACE(REPLACE(TRIM(ndc_code),"-","")," ",""),"*",""),11)</property>
                        <property name="FriendlyExpression" dataType="System.String">Standardize NDC to 11-digit format by removing hyphens/spaces and left-padding with zeros</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output].Columns[ndc_formatted]"
                      dataType="wstr"
                      length="13"
                      lineageId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output].Columns[ndc_formatted]"
                      name="ndc_formatted">
                      <properties>
                        <property name="Expression" dataType="System.String">SUBSTRING(RIGHT("00000000000" + REPLACE(REPLACE(REPLACE(TRIM(ndc_code),"-","")," ",""),"*",""),11),1,5) + "-" + SUBSTRING(RIGHT("00000000000" + REPLACE(REPLACE(REPLACE(TRIM(ndc_code),"-","")," ",""),"*",""),11),6,4) + "-" + SUBSTRING(RIGHT("00000000000" + REPLACE(REPLACE(REPLACE(TRIM(ndc_code),"-","")," ",""),"*",""),11),10,2)</property>
                        <property name="FriendlyExpression" dataType="System.String">Format NDC as 5-4-2 with hyphens</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output].Columns[rx_year]"
                      dataType="i4"
                      lineageId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output].Columns[rx_year]"
                      name="rx_year">
                      <properties>
                        <property name="Expression" dataType="System.String">YEAR(fill_date)</property>
                        <property name="FriendlyExpression" dataType="System.String">Extract year from fill date for aggregation</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- Row Count: Pharmacy -->
            <component
              refId="Package\DFT_TransformPharmacy\RC_Pharmacy"
              componentClassID="Microsoft.RowCount"
              description="Count pharmacy rows processed"
              name="RC_Pharmacy">
              <properties>
                <property name="VariableName" dataType="System.String">User::RowCount_Pharmacy</property>
              </properties>
              <inputs>
                <input refId="Package\DFT_TransformPharmacy\RC_Pharmacy.Inputs[Row Count Input 1]" name="Row Count Input 1"/>
              </inputs>
              <outputs>
                <output refId="Package\DFT_TransformPharmacy\RC_Pharmacy.Outputs[Row Count Output 1]" name="Row Count Output 1" synchronousInputId="Package\DFT_TransformPharmacy\RC_Pharmacy.Inputs[Row Count Input 1]"/>
              </outputs>
            </component>

            <!-- Destination: Transformed Pharmacy -->
            <component
              refId="Package\DFT_TransformPharmacy\DST_TransformedPharmacy"
              componentClassID="Microsoft.OLEDBDestination"
              contactInfo="OLE DB Destination"
              description="Load transformed pharmacy data"
              name="DST_TransformedPharmacy"
              usesDispositions="true"
              version="4">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="OpenRowset" dataType="System.String">dbo.pharmacy_transformed</property>
                <property name="AccessMode" dataType="System.Int32">3</property>
                <property name="FastLoadKeepIdentity" dataType="System.Boolean">false</property>
                <property name="FastLoadKeepNulls" dataType="System.Boolean">false</property>
                <property name="FastLoadMaxInsertCommitSize" dataType="System.Int32">2147483647</property>
                <property name="FastLoadOptions" dataType="System.String">TABLOCK,CHECK_CONSTRAINTS</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_TransformPharmacy\DST_TransformedPharmacy.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[TargetDB]"
                  connectionManagerRefId="Package.ConnectionManagers[TargetDB]"
                  name="OleDbConnection"/>
              </connections>
              <inputs>
                <input refId="Package\DFT_TransformPharmacy\DST_TransformedPharmacy.Inputs[OLE DB Destination Input]" name="OLE DB Destination Input"/>
              </inputs>
            </component>

          </components>

          <!-- Data Flow Paths for Pharmacy Transform -->
          <paths>
            <path refId="Package\DFT_TransformPharmacy.Paths[Source to NDC]"
              endId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Inputs[Derived Column Input]"
              name="Source to NDC"
              startId="Package\DFT_TransformPharmacy\SRC_PBMPharmacy.Outputs[OLE DB Source Output]"/>
            <path refId="Package\DFT_TransformPharmacy.Paths[NDC to RowCount]"
              endId="Package\DFT_TransformPharmacy\RC_Pharmacy.Inputs[Row Count Input 1]"
              name="NDC to RowCount"
              startId="Package\DFT_TransformPharmacy\DER_NDCStandardization.Outputs[Derived Column Output]"/>
            <path refId="Package\DFT_TransformPharmacy.Paths[RowCount to Destination]"
              endId="Package\DFT_TransformPharmacy\DST_TransformedPharmacy.Inputs[OLE DB Destination Input]"
              name="RowCount to Destination"
              startId="Package\DFT_TransformPharmacy\RC_Pharmacy.Outputs[Row Count Output 1]"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ========================================== -->
    <!-- TASK 4: Data Flow - Member Claims Aggregation -->
    <!-- ========================================== -->
    <DTS:Executable
      DTS:refId="Package\DFT_MemberClaimsAggregation"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:Description="Aggregate claims data by member: total claims, inpatient claims, paid amounts"
      DTS:DTSID="{DFT00004-0004-0004-0004-000000000004}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="DFT_MemberClaimsAggregation"
      DTS:TaskContact="Microsoft Corporation; Microsoft SQL Server; Microsoft Corporation">

      <DTS:ObjectData>
        <pipeline version="1">
          <components>

            <!-- Source: Transformed Claims for Aggregation -->
            <component
              refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source"
              description="Read transformed claims for aggregation"
              name="SRC_ClaimsForAgg"
              usesDispositions="true"
              version="7">
              <properties>
                <property name="CommandTimeout" dataType="System.Int32">0</property>
                <property name="AccessMode" dataType="System.Int32">2</property>
                <property name="SqlCommand" dataType="System.String">SELECT
    member_id,
    claim_id,
    is_inpatient,
    paid_amount,
    total_charge_amount,
    service_date_start,
    service_date_end,
    claim_year
FROM dbo.claims_transformed</property>
              </properties>
              <connections>
                <connection refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Connections[OleDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[TargetDB]"
                  connectionManagerRefId="Package.ConnectionManagers[TargetDB]"
                  name="OleDbConnection"/>
              </connections>
              <outputs>
                <output refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output]"
                  name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[member_id]" dataType="wstr" length="50" name="member_id"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[claim_id]" dataType="wstr" length="50" name="claim_id"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[is_inpatient]" dataType="bool" name="is_inpatient"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[paid_amount]" dataType="numeric" precision="10" scale="2" name="paid_amount"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[total_charge_amount]" dataType="numeric" precision="10" scale="2" name="total_charge_amount"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[service_date_start]" dataType="dbDate" name="service_date_start"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[service_date_end]" dataType="dbDate" name="service_date_end"/>
                    <outputColumn refId="Package\DFT_MemberClaimsAggregation\SRC_ClaimsForAgg.Outputs[OLE DB Source Output].Columns[claim_year]" dataType="i4" name="claim_year"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

