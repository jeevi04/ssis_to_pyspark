# ── LLM Provider Configuration ────────────────────────────────────────────────
# Set the provider in config/default.yaml or override with LLM_PROVIDER env var

# Anthropic (Claude) — recommended
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Azure OpenAI Codex (gpt-5.3-codex)
AZURE_OPENAI_CODEX_API_KEY=your_azure_openai_codex_api_key_here

# Azure AI Foundry (Anthropic Claude on Azure)
AZURE_ANTHROPIC_API_KEY=your_azure_anthropic_api_key_here

# Databricks
DATABRICKS_TOKEN=your_databricks_token_here
DATABRICKS_WORKSPACE_URL=https://your-workspace.azuredatabricks.net

# ── Database Connection (used in generated output code) ────────────────────────
# These are NOT used by the converter — they appear as env var references
# in the generated bronze/silver/gold PySpark modules so your team knows
# what to set when deploying the converted pipeline.
DB_HOST=your-sql-server.database.windows.net
DB_PORT=1433
SOURCE_DB_NAME=SourceDB
TARGET_DB_NAME=TargetDB
DB_USER=etl_service_account
DB_PASSWORD=your_db_password_here

# Optional: separate NPI lookup DB
NPI_DB_NAME=NPIRegistry
NPI_DB_HOST=your-sql-server.database.windows.net
